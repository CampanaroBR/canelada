generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Migrações no Neon precisam de conexão DIRETA (sem pgbouncer) — advisory
  // locks de sessão não funcionam direito com pooling em modo transação.
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  apelido       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  jogador       Jogador?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?  
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Grupo {
  id          String   @id @default(cuid())
  nome        String
  slug        String   @unique
  inviteCode  String   @unique @default(dbgenerated("gen_random_uuid()"))
  createdAt   DateTime @default(now())

  jogadores   Jogador[]
  rodadas     Rodada[]
}

enum RoleGrupo {
  SUPER_ADMIN
  ADMIN
  PLAYER
}

model Jogador {
  id          String    @id @default(cuid())
  userId      String    @unique
  grupoId     String
  apelido     String
  nomeNoBaba  String?
  nome        String?
  sobrenome   String?
  posicao     String?
  peDominante String?
  foto        String?
  role        RoleGrupo @default(PLAYER)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
  grupo       Grupo     @relation(fields: [grupoId], references: [id])
  votosRecebidos  Voto[]   @relation("VotadoVotos")
  votosEmitidos   Voto[]   @relation("VotanteVotos")
  traitsRecebidas JogadorTrait[]
  pushSubscriptions PushSubscription[]
  badgeUnlocks    BadgeUnlock[]
  rodadasPresente Rodada[]       @relation("RodadaPresentes")
}

model BadgeUnlock {
  id         String   @id @default(cuid())
  jogadorId  String
  slug       String
  createdAt  DateTime @default(now())

  jogador    Jogador  @relation(fields: [jogadorId], references: [id], onDelete: Cascade)

  @@unique([jogadorId, slug])
  @@index([jogadorId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  jogadorId String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  jogador   Jogador  @relation(fields: [jogadorId], references: [id], onDelete: Cascade)
}

model Rodada {
  id             String       @id @default(cuid())
  grupoId        String
  data           DateTime     @default(now())
  encerrada      Boolean      @default(false)
  votacaoAberta  Boolean      @default(false)
  createdAt      DateTime     @default(now())
  // Nomes da lista do baba que não tinham conta no app na hora da criação da
  // rodada. Admin resolve depois (antes ou durante a votação) associando
  // cada nome a um jogador cadastrado, em /votacao/presenca.
  pendentes      String[]     @default([])

  grupo       Grupo        @relation(fields: [grupoId], references: [id])
  votos       Voto[]
  stories     Story[]
  // Lista de presença: quem realmente jogou (ou foi marcado presente) nessa
  // rodada, editável manualmente. Vazio = sem restrição (mostra todo o grupo,
  // comportamento antigo — mantém rodadas passadas funcionando sem migração).
  presentes   Jogador[]    @relation("RodadaPresentes")
}

model Voto {
  id          String     @id @default(cuid())
  rodadaId    String
  votanteId   String
  votadoId    String
  categoria   CategoriaVoto
  traitSlug   String?
  createdAt   DateTime   @default(now())

  rodada      Rodada     @relation(fields: [rodadaId], references: [id])
  votante     Jogador    @relation("VotanteVotos", fields: [votanteId], references: [id])
  votado      Jogador    @relation("VotadoVotos", fields: [votadoId], references: [id])
  trait       Trait?     @relation(fields: [traitSlug], references: [slug])

  @@unique([rodadaId, votanteId, categoria, traitSlug])
}

enum CategoriaVoto {
  MVP
  BAGRE
  RACUDO
  RESENHA
  TRAIT
}

model Trait {
  slug        String         @id
  nome        String
  descricao   String?
  categoria   TraitCategoria
  emoji       String?
  // Peso pro placar ponderado da Seleção da Rodada (score = peso × nº de
  // votos, somado por jogador entre todos os traits do mesmo lado). 3 =
  // decide o jogo sozinho (Matador, Categoria, Paredão, Bagre da Noite,
  // Frangueiro), 2 = impacto real (Raçudo, Xerife, Driblador, Garçom,
  // Bragueiro, Reclamão, Pregueiro), 1 = mais estilo/comportamento que
  // resultado (Resenha Forte, Paneleiro, Firuleiro). Default 1 pra traits
  // fora da votação ativa.
  peso        Int            @default(1)

  jogadores   JogadorTrait[]
  votos       Voto[]
}

enum TraitCategoria {
  FUTEBOL
  PERSONALIDADE
  RESENHA
}

model JogadorTrait {
  id          String   @id @default(cuid())
  jogadorId   String
  traitSlug   String
  contador    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jogador     Jogador  @relation(fields: [jogadorId], references: [id])
  trait       Trait    @relation(fields: [traitSlug], references: [slug])

  @@unique([jogadorId, traitSlug])
}

model Story {
  id          String    @id @default(cuid())
  rodadaId    String
  texto       String
  tipo        StoryTipo
  createdAt   DateTime  @default(now())

  rodada      Rodada    @relation(fields: [rodadaId], references: [id])
}

enum StoryTipo {
  MVP
  BAGRE
  TRAIT_CONQUISTADA
  SELECAO
  SEQUENCIA
}
